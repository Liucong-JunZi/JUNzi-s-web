# ==================== 服务器配置 ====================
GIN_MODE=release
SERVER_PORT=8080

# ==================== 数据库配置 ====================
DB_HOST=mysql
DB_PORT=3306
DB_USER=junzi
# REQUIRED: Generate a strong password (at least 16 characters)
# Example: openssl rand -base64 32
DB_PASSWORD=<CHANGE_ME>
DB_NAME=personal_website

# ==================== Redis 配置 ====================
REDIS_HOST=redis
REDIS_PORT=6379
# REQUIRED: Generate a strong password
# Example: openssl rand -base64 32
REDIS_PASSWORD=<CHANGE_ME>

# ==================== MinIO 配置 ====================
MINIO_ENDPOINT=minio:9000
# REQUIRED: Generate strong access keys
# Example: openssl rand -hex 16
MINIO_ACCESS_KEY=<CHANGE_ME>
MINIO_SECRET_KEY=<CHANGE_ME>
MINIO_BUCKET=uploads
MINIO_USE_SSL=false
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ==================== GitHub OAuth 配置 ====================
# REQUIRED: Replace with your GitHub OAuth App credentials
# Create OAuth App: https://github.com/settings/developers
GITHUB_CLIENT_ID=<YOUR_GITHUB_CLIENT_ID>
GITHUB_CLIENT_SECRET=<YOUR_GITHUB_CLIENT_SECRET>
GITHUB_CALLBACK_URL=http://localhost:8080/api/auth/github/callback

# ==================== JWT 配置 ====================
# REQUIRED: Generate a strong secret key (minimum 32 characters)
# Must use at least 3 character categories (uppercase, lowercase, digits, special chars)
# Do NOT use placeholder values like "change_me" or "secret-key"
# Generate: openssl rand -base64 32
JWT_SECRET=<CHANGE_ME>

# ==================== CORS 配置 ====================
# Comma-separated list of allowed origins
# Example: https://example.com,https://app.example.com
CORS_ALLOWED_ORIGINS=http://localhost

# ==================== 前端配置 ====================
FRONTEND_PORT=80
VITE_API_URL=http://localhost:8080

# ==================== 安全注意事项 ====================
# 1. 所有标记为 REQUIRED 的变量必须在生产环境中设置
# 2. 使用以下命令生成强密钥:
#    openssl rand -base64 32   (用于密码和密钥)
#    openssl rand -hex 16      (用于 MinIO access key)
# 3. 不要在生产环境中使用示例值
# 4. 确保 .env 文件不被提交到版本控制系统