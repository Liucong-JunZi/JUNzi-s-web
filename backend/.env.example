# ==================== 本地开发配置 ====================
# WARNING: This file is for LOCAL DEVELOPMENT only.
# For production, use the root .env file and set all <CHANGE_ME> placeholders.
# Run `make generate-secrets` to generate secure random values.
# ====================

# Server
SERVER_PORT=8080
GIN_MODE=release

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=junzi
DB_PASSWORD=<CHANGE_ME>
DB_NAME=personal_website

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<CHANGE_ME>

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=<CHANGE_ME>
MINIO_SECRET_KEY=<CHANGE_ME>
MINIO_BUCKET=uploads
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000

# GitHub OAuth
GITHUB_CLIENT_ID=<CHANGE_ME>
GITHUB_CLIENT_SECRET=<CHANGE_ME>
GITHUB_CALLBACK_URL=http://localhost:8080/api/auth/github/callback

# JWT (must be 32+ chars with mixed case, digits, and special characters)
JWT_SECRET=<CHANGE_ME>
