{
  "name": "Anonymous User Tests",
  "description": "TPC test suite for S_ANON",
  "testCases": [
    {
      "id": "TC_T_NAV_T_LOGIN",
      "name": "Navigate → Login",
      "description": "Test Navigate to a page followed by User logs in via GitHub OAuth",
      "actor": "S_ANON",
      "initialState": {
        "actor": "S_ANON",
        "page": "P_HOME",
        "isAuthenticated": false
      },
      "transitions": [
        {
          "type": "nav"
        },
        {
          "type": "login"
        }
      ],
      "assertions": [
        {
          "type": "state_invariant",
          "target": "header",
          "expected": "S_ANON"
        }
      ],
      "priority": "high",
      "tags": [
        "nav",
        "login",
        "anonymous",
        "user",
        "admin"
      ]
    },
